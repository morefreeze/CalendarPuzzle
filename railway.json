{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "providers": ["python"],
      "install": ["pip install -r requirements.txt"]
    }
  },
  "deploy": {
    "restartPolicy": {
      "type": "ON_FAILURE",
      "delay": 5
    },
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 10,
    "startCommand": "python server.py",
    "numReplicas": 1
  },
  "vars": {
    "PORT": "5001",
    "FLASK_ENV": "production"
  }
}
